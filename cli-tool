#!/bin/bash
# YouTube upload/download wrapper script

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV="$SCRIPT_DIR/venv/bin/activate"
PYTHON="$SCRIPT_DIR/venv/bin/python"
TOOL="$SCRIPT_DIR/youtube-upload.py"

# Activate virtual environment
if [ -f "$VENV" ]; then
    source "$VENV"
else
    echo "❌ Virtual environment not found. Run: cd tools && python3 -m venv venv"
    exit 1
fi

# Run the tool
python3 "$TOOL" "$@"
